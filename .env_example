# Ollama LLM configuration
# During local development: use localhost:11434
# Inside Docker containers: use host.docker.internal:11434
OLLAMA_URL=http://host.docker.internal:11434
OLLAMA_MODEL=llama3.2:3b

# Database
# During local development: use a local relative path
# Inside Docker containers: use /app/storage/ml_platform.db
DATABASE_URL=sqlite+aiosqlite:////app/storage/ml_platform.db

# Storage directory for datasets, artifacts, notebooks, profiles, logs
# Inside Docker: /app/storage
# Local dev: adjust to your local absolute path
STORAGE_DIR=/app/storage

# Logging level: DEBUG, INFO, WARNING, ERROR
LOG_LEVEL=INFO