# Copy this file to .env and fill in values for your environment.
# For local development (outside Docker), paths are relative.
# For Docker deployment, use the absolute /app/storage paths shown below.

# --- Ollama LLM ---
# Docker Desktop (Windows/Mac): host.docker.internal
# Linux Docker: 172.17.0.1
OLLAMA_URL=http://host.docker.internal:11434
OLLAMA_MODEL=llama3.2:3b

# --- Database ---
# Local dev (relative path):
#   DATABASE_URL=sqlite+aiosqlite:///./storage/ml_platform.db
# Docker (absolute path, 4 slashes required):
DATABASE_URL=sqlite+aiosqlite:////app/storage/ml_platform.db

# --- Storage ---
# Local dev:
#   STORAGE_DIR=./storage
# Docker:
STORAGE_DIR=/app/storage

# --- Logging ---
LOG_LEVEL=INFO